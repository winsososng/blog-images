# ═══════════════════════════════════════
# .gitignore — 수학 블로그 (Git 중심 동기화 정책)
# ═══════════════════════════════════════
# 원칙: 모든 PC가 Git을 통해 동일한 구조에서 작업
# Git에 안 올리는 것 = 보안 / 임시파일 / 별도 보관(동영상)만
# ═══════════════════════════════════════

# Git 작업 안전망 (임시 폴더)
_local_backup/
_remote_preview/

# 보안 (절대 push 금지)
NaverBlogProfile/
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json
config_local.json

# Python 캐시
__pycache__/
*.pyc
*.pyo
*.pyd

# OS 임시파일
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# 에디터 개인 설정
.vscode/
.idea/
*.swp
*.swo
*~

# 백업 파일
*.bak
*.backup
*.old

# 동영상 (로컬 + Google Drive + YouTube에 별도 보관)
*.mp4
*.mov
*.avi
*.mkv
*.webm

# Manim 관련 (재생성 가능)
media/
manim_env/
venv/
.venv/

# LaTeX 컴파일 임시
*.aux
*.toc
*.log
*.out
*.synctex.gz
_tex_work/

# 임시 작업
*.tmp
~$*
~*

# 노트북
.ipynb_checkpoints/
